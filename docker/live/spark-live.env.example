# Copy to spark-live.env and fill with real platform secrets.
# Keep spark-live.env out of source control.

SPARK_ALLOWED_HOSTS=your-spark-host.example.com
SPARK_UI_API_KEY=replace-with-a-random-value-at-least-24-chars
SPARK_BRIDGE_API_KEY=replace-with-a-different-random-value-at-least-24-chars

# Monolith mode: Spark Live owns Telegram polling.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# Split mode: a separate spark-telegram-bot owns Telegram polling.
# SPARK_LIVE_TELEGRAM_MODE=external

SPARK_LLM_PROVIDER=zai
ZAI_API_KEY=
SPARK_MODEL=
